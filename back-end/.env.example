# App
PORT=3000
NODE_ENV=development

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=multitenant
DATABASE_PASSWORD=multitenant
DATABASE_NAME=multitenant

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# PASSWORD RESET SECRET
PASSWORD_RESET_SECRET=

# Organização principal (sem tabela — apenas config)
ORG_NAME="Minha Empresa"
ORG_ADMIN_EMAIL=admin@system.com
ORG_ADMIN_PASSWORD=

# Usuário de sistema (operações automatizadas do bootstrap)
# Gerar com: openssl rand -base64 32
SYS_USER_PASSWORD=
